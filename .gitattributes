# Normalize line endings for all text files
* text=auto eol=lf

# Shell scripts must always use LF
*.sh text eol=lf

# Nginx templates must use LF
*.conf text eol=lf
*.conf.template text eol=lf

# PHP and web files
*.php text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf

# Binary files — no conversion
*.jpeg binary
*.jpg binary
*.png binary
*.webp binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.docx binary
