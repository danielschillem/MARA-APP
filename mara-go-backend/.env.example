PORT=8081
APP_ENV=development

# SQLite (dev) — fichier local
DATABASE_URL=file:mara.db?cache=shared&mode=rwc

# PostgreSQL (prod — décommentez et remplissez pour la production)
# DATABASE_URL=host=localhost user=mara password=secret dbname=mara_db port=5432 sslmode=disable

# JWT — minimum 32 caractères. Générer avec: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_a_32_char_minimum_secret

FRONTEND_URL=http://localhost:5174
FLUTTER_URL=http://localhost:3000

# ReliefWeb API (public, pas de clé requise)
RELIEFWEB_URL=https://api.reliefweb.int/v1

MAX_UPLOAD_MB=20
UPLOAD_DIR=uploads

# Mettre à false en production
DB_SEED=true
